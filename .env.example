# Patent Analyzer — Environment Variables
# Copy to .env and fill in:  cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────
# LLM API key (works with any OpenAI-compatible provider)
LLM_API_KEY=sk-...

# SerpAPI key for Google Patents + Scholar search (https://serpapi.com)
SERPAPI_KEY=your_serpapi_key_here

# ── Optional ──────────────────────────────────────────────────────────
# LLM model name (default: gpt-4o)
# Examples:
#   OpenAI:     gpt-4o, gpt-4o-mini, o1
#   Gemini:     gemini-2.5-flash (set LLM_BASE_URL below)
#   DeepSeek:   deepseek-chat
#   Groq:       llama-3.1-70b-versatile
#   Local:      any model via Ollama
LLM_MODEL=gpt-4o

# LLM API base URL (default: https://api.openai.com/v1)
# Change for different providers:
#   Gemini:   https://generativelanguage.googleapis.com/v1beta/openai
#   DeepSeek: https://api.deepseek.com/v1
#   Groq:     https://api.groq.com/openai/v1
#   Ollama:   http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

# Output directory (default: ./outputs)
OUTPUT_DIR=./outputs
